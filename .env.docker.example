# Copiar a .env (junto al docker-compose.yml) y completar.
# NO subir el .env real al repositorio.

# Contraseña de PostgreSQL (elegir una fuerte)
POSTGRES_PASSWORD=cambiar-esta-contrasena

# Clave para firmar los JWT (generar una aleatoria, p. ej.:
#   python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=cambiar-esta-clave

# URL del backend vista desde el navegador del usuario del panel web.
# En local: http://localhost:8000 — en un servidor: https://api.tudominio.com
API_URL_PUBLICA=http://localhost:8000
