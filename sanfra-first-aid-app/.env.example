# Variables de entorno para el despliegue con docker-compose.
# Copiar a .env (en esta misma carpeta) y completar.
# NO subir el .env real al repositorio.

# ============================================================
# BASE DE DATOS (PostgreSQL)
# ============================================================

# Contraseña de PostgreSQL (elegir una fuerte). El backend la usa
# automáticamente para armar su DATABASE_URL.
POSTGRES_PASSWORD=cambiar-esta-contrasena

# ============================================================
# BACKEND (API FastAPI + IA) — oppadev/first-aid
# ============================================================

# Clave para firmar los JWT (generar una aleatoria, p. ej.:
#   python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=cambiar-esta-clave

# Orígenes permitidos para CORS, separados por coma.
# "*" permite todos (demo local); en producción restringir al origen del
# panel web, p. ej.: CORS_ORIGINS=https://panel.tudominio.com
CORS_ORIGINS=*

# Puerto del servidor en el que se expone la API.
BACKEND_PORT=8000

# ============================================================
# FRONTEND (panel web nginx) — oppadev/web-first-aid
# ============================================================

# Puerto del servidor en el que se expone el panel web.
FRONTEND_PORT=8080

# NOTA: la URL del backend que usa el panel (EXPO_PUBLIC_API_URL) NO se
# configura aquí: va horneada en la imagen en tiempo de build. Si cambia el
# dominio/IP del servidor, reconstruir y republicar la imagen (ver README).
