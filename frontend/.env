# URL del backend. Debe ser la IP LAN de la PC (no localhost) para que el celular la alcance.
# Si cambias de red, actualiza esta IP (corre `ipconfig` y usa la IPv4 de tu Wi-Fi).
EXPO_PUBLIC_API_URL=http://192.168.105.64:8000

# Lectura por voz (TTS) del protocolo.
# Velocidad: 1.0 = normal; súbelo para leer más rápido (p. ej. 1.15, 1.3).
EXPO_PUBLIC_VOZ_VELOCIDAD=1.3
# Idioma de la voz (BCP-47): "es", "es-ES", "es-419", etc.
EXPO_PUBLIC_VOZ_IDIOMA=es
