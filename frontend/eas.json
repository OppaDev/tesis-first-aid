{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://www.oppadev.com",
        "EXPO_PUBLIC_VOZ_VELOCIDAD": "1.3",
        "EXPO_PUBLIC_VOZ_IDIOMA": "es"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://www.oppadev.com",
        "EXPO_PUBLIC_VOZ_VELOCIDAD": "1.3",
        "EXPO_PUBLIC_VOZ_IDIOMA": "es"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://www.oppadev.com",
        "EXPO_PUBLIC_VOZ_VELOCIDAD": "1.3",
        "EXPO_PUBLIC_VOZ_IDIOMA": "es"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
